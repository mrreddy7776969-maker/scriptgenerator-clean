# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── AI Providers (add at least ONE — Groq recommended) ──────────────────────

# RECOMMENDED: Groq — free, fast, no quota headaches (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# OPTIONAL: OpenRouter — free model fallbacks (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your_key_here

# OPTIONAL: Google Gemini — fallback if Groq fails
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Force a single provider: groq | openrouter | gemini (default: try all configured)
# LLM_PROVIDER=groq

# Admin (unlimited scripts + admin dashboard)
ADMIN_EMAIL=mrreddy7776969@gmail.com

# Pricing defaults (INR)
PRO_PRICE=50
PRO_PLUS_PRICE=150

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_PLUS_PRICE_ID=price_...
